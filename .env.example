# =====================================================
# Simulator-Experiment (YDEX) — environment variables
# Copy to .env.local and fill in real values for local dev.
# .env.local is gitignored; never commit it.
# =====================================================

# App URL.
NEXT_PUBLIC_APP_URL=

# Solana program (devnet). Public on-chain identifier.
NEXT_PUBLIC_PROGRAM_ID=
NEXT_PUBLIC_DERIVERSE_VERSION=

# RPC. Optional — falls back to https://api.devnet.solana.com if unset.
# Do NOT put real Helius/QuickNode keys behind a NEXT_PUBLIC_* var; those
# ship to the browser. Use a SERVER-ONLY proxy route instead.
NEXT_PUBLIC_HELIUS_RPC_URL=
NEXT_PUBLIC_RPC_HTTP=
NEXT_PUBLIC_RPC_DEVNET=
NEXT_PUBLIC_RPC_MAINNET=
NEXT_PUBLIC_WALLET_CLUSTER=devnet

# Supabase. Anon key requires RLS to be enabled and policies scoped per user.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secrets (not exposed to the browser).
GEMINI_API_KEY=
